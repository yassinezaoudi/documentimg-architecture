workspace "Система управления рестораном" "Вариант 17: система управления рестораном наподобие OpenTable" {

    model {

        # Пользователи
        person "Клиент" "Посетитель ресторана, который регистрируется, просматривает меню и создаёт заказы" {
            tags "User"
        }

        person "Сотрудник" "Работник ресторана, который управляет меню и статусами заказов" {
            tags "User"
        }

        # Внешние системы
        softwareSystem "Платёжный шлюз" "Внешняя система обработки платежей (например, Stripe)" {
            tags "External"
        }

        softwareSystem "Сервис электронной почты" "Внешний сервис отправки email-уведомлений (например, SendGrid)" {
            tags "External"
        }

        # Основная система
        softwareSystem "Система управления рестораном" "Позволяет клиентам просматривать меню и оформлять заказы, а сотрудникам управлять меню и заказами" {

            tags "System"

            # Контейнеры
            container "Веб-приложение" "Одностраничное приложение для клиентов и сотрудников" {
                technology "React, HTML, CSS"
                tags "Container"
            }

            container "API шлюз" "Единая точка входа для всех клиентских запросов" {
                technology "Spring Cloud Gateway"
                tags "Container"
            }

            container "Сервис пользователей" "Управляет регистрацией пользователей и поиском" {
                technology "Spring Boot REST API"
                tags "Container"
            }

            container "Сервис меню" "Управляет блюдами и категориями" {
                technology "Spring Boot REST API"
                tags "Container"
            }

            container "Сервис заказов" "Управляет заказами, позициями заказа и изменением статусов" {
                technology "Spring Boot REST API"
                tags "Container"
            }

            container "База данных пользователей" "Хранит данные пользователей" {
                technology "PostgreSQL"
                tags "Database"
            }

            container "База данных меню" "Хранит данные блюд и категорий" {
                technology "PostgreSQL"
                tags "Database"
            }

            container "База данных заказов" "Хранит данные заказов и позиций заказа" {
                technology "PostgreSQL"
                tags "Database"
            }

            # Связи между контейнерами
            "Веб-приложение" -> "API шлюз" "Использует" "HTTPS/REST"

            "API шлюз" -> "Сервис пользователей" "Перенаправляет запросы в" "HTTPS/REST"
            "API шлюз" -> "Сервис меню" "Перенаправляет запросы в" "HTTPS/REST"
            "API шлюз" -> "Сервис заказов" "Перенаправляет запросы в" "HTTPS/REST"

            "Сервис пользователей" -> "База данных пользователей" "Чтение и запись данных пользователей" "JDBC"
            "Сервис меню" -> "База данных меню" "Чтение и запись данных меню" "JDBC"
            "Сервис заказов" -> "База данных заказов" "Чтение и запись данных заказов" "JDBC"

            # Взаимодействие сервисов
            "Сервис заказов" -> "Сервис пользователей" "Проверяет существование пользователя" "HTTPS/REST"
            "Сервис заказов" -> "Сервис меню" "Получает цены блюд" "HTTPS/REST"

            # Связи с внешними системами
            "Сервис заказов" -> "Платёжный шлюз" "Инициирует оплату" "HTTPS/REST"
            "Сервис заказов" -> "Сервис электронной почты" "Отправляет подтверждение заказа" "HTTPS/REST"
        }

        # Связи пользователей с системой
        "Клиент" -> "Система управления рестораном" "Просматривает меню и создаёт заказы"
        "Сотрудник" -> "Система управления рестораном" "Управляет меню и заказами"

        # Связи системы с внешними сервисами
        "Система управления рестораном" -> "Платёжный шлюз" "Обрабатывает платежи через"
        "Система управления рестораном" -> "Сервис электронной почты" "Отправляет уведомления через"
    }

    views {

        # Диаграмма контекста системы
        systemContext "Система управления рестораном" {

            include *
            autoLayout

            title "Диаграмма контекста системы — Система управления рестораном"
            description "Показывает систему в контексте пользователей и внешних систем."
        }

        # Контейнерная диаграмма
        container "Система управления рестораном" {

            include *
            autoLayout

            title "Контейнерная диаграмма — Система управления рестораном"
            description "Показывает основные технические компоненты системы."
        }

        # Динамическая диаграмма: создание заказа
        dynamic "Система управления рестораном" "Создание заказа" {

            "Клиент" -> "Веб-приложение" "Нажимает «Оформить заказ»"
            "Веб-приложение" -> "API шлюз" "POST /orders"

            "API шлюз" -> "Сервис заказов" "POST /orders"

            "Сервис заказов" -> "Сервис пользователей" "GET /users/{userId}"
            "Сервис пользователей" -> "База данных пользователей" "SELECT user"
            "Сервис пользователей" -> "Сервис заказов" "Данные пользователя"

            "Сервис заказов" -> "Сервис меню" "GET /dishes?ids=..."
            "Сервис меню" -> "База данных меню" "SELECT dishes"
            "Сервис меню" -> "Сервис заказов" "Цены блюд"

            "Сервис заказов" -> "База данных заказов" "INSERT orders + order_items"

            "Сервис заказов" -> "Платёжный шлюз" "Создать платёж"
            "Сервис заказов" -> "Сервис электронной почты" "Отправить подтверждение заказа"

            "Сервис заказов" -> "API шлюз" "Заказ создан"
            "API шлюз" -> "Веб-приложение" "201 Created"

            "Веб-приложение" -> "Клиент" "Показывает подтверждение заказа"

            autoLayout

            title "Динамическая диаграмма — Создание заказа"
            description "Последовательность взаимодействий при создании нового заказа."
        }

        # Стили элементов
        styles {

            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }

            element "System" {
                background #1168bd
                color #ffffff
            }

            element "Container" {
                background #438dd5
                color #ffffff
            }

            element "Database" {
                shape Cylinder
                background #438dd5
                color #ffffff
            }

            element "External" {
                background #999999
                color #ffffff
            }
        }

        defaultView {
            autoLayout
        }
    }
}
